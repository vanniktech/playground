ALTER TABLE feedback_coach_allow DROP CONSTRAINT IF EXISTS feedback_coach_allow_pkey;

ALTER TABLE target_activity ADD CONSTRAINT target_activity_pkey PRIMARY KEY ('id');
ALTER TABLE coach_tag_coachee ADD CONSTRAINT coach_tag_coachee_pkey PRIMARY KEY ('id');
ALTER TABLE feedback_coach_allow ADD CONSTRAINT feedback_coach_allow_pkey PRIMARY KEY ('id');
