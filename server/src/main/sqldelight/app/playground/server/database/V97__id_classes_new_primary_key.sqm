ALTER TABLE target_activity ALTER COLUMN id DROP DEFAULT;
ALTER TABLE coach_tag_coachee ALTER COLUMN id DROP DEFAULT;
ALTER TABLE feedback_coach_allow ALTER COLUMN id DROP DEFAULT;

ALTER TABLE target_activity DROP CONSTRAINT IF EXISTS target_activity_pkey;
